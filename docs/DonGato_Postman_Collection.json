						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Latte SQA {{$timestamp}}\",\n    \"description\": \"Café latte con sirope de vainilla\",\n    \"price\": 3.50,\n    \"categoryId\": {{category_id}}\n}"
