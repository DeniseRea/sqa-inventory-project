								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"productId\": {{product_id}},\n    \"quantity\": 15,\n    \"type\": \"ENTRADA\",\n    \"reason\": \"REPOSICION\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/stock-movements",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
