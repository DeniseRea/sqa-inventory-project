					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Final stock should be exactly 13 (15 entry - 2 exit)\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.stock).to.eql(13);",
